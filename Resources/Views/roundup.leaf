<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moa 반기 성과 취합 — #(halfLabel)</title>
    <style>
        :root { --kurly: #5f0080; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background:#f5f5f7; color:#1d1d1f; margin:0; padding:0 0 120px; }
        .wrap { max-width: 860px; margin: 0 auto; padding: 24px 16px; }
        header.top { background:#fff; border-radius:14px; padding:20px 24px; box-shadow:0 1px 3px rgba(0,0,0,.08); margin-bottom:20px; }
        header.top h1 { margin:0 0 6px; font-size:1.5rem; }
        .meta { color:#6e6e73; font-size:.95rem; }
        .stats { display:flex; flex-wrap:wrap; gap:10px; margin-top:14px; }
        .chip { background:#f0e6f5; color:var(--kurly); border-radius:999px; padding:6px 12px; font-size:.85rem; font-weight:600; }
        .chip.gray { background:#eee; color:#555; }
        section.bucket { background:#fff; border-radius:14px; padding:18px 22px; box-shadow:0 1px 3px rgba(0,0,0,.08); margin-bottom:18px; }
        section.bucket h2 { font-size:1.15rem; margin:0 0 4px; display:flex; align-items:center; gap:8px; }
        section.bucket .desc { color:#8a8a8e; font-size:.85rem; margin:0 0 14px; }
        .group { border:1px solid #ececf0; border-radius:10px; padding:12px 14px; margin-bottom:12px; }
        .group.locked { background:#faf7fc; border-color:#e6d9ef; }
        .group .ghead { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; flex-wrap:wrap; }
        .group .gtitle { font-weight:600; font-size:.98rem; }
        .group .gtitle a { color:var(--kurly); text-decoration:none; font-weight:700; }
        .group .gcount { color:#8a8a8e; font-size:.85rem; white-space:nowrap; }
        .radios { display:flex; gap:6px; margin-top:8px; }
        .radios label { border:1px solid #d2d2d7; border-radius:8px; padding:5px 12px; font-size:.85rem; cursor:pointer; user-select:none; }
        .radios input { display:none; }
        .radios label:has(input:checked) { background:var(--kurly); color:#fff; border-color:var(--kurly); }
        .lockbadge { display:inline-block; margin-top:8px; background:var(--kurly); color:#fff; border-radius:8px; padding:5px 12px; font-size:.82rem; font-weight:600; }
        ul.tks { margin:10px 0 0; padding-left:18px; }
        ul.tks li { font-size:.9rem; margin:3px 0; }
        ul.tks li a { color:#0071e3; text-decoration:none; }
        ul.tks li .v { color:#a1a1a6; font-size:.8rem; margin-left:6px; }
        .empty { color:#b0b0b5; font-size:.9rem; }
        .footer-bar { position:fixed; bottom:0; left:0; right:0; background:#fff; border-top:1px solid #e5e5ea; padding:14px 16px; box-shadow:0 -1px 6px rgba(0,0,0,.06); }
        .footer-inner { max-width:860px; margin:0 auto; display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
        .footer-inner input { flex:1; min-width:160px; padding:.7rem; border:1px solid #d2d2d7; border-radius:8px; font-size:.95rem; }
        .btn { background:var(--kurly); color:#fff; border:none; border-radius:8px; padding:.8rem 1.2rem; font-size:.9rem; font-weight:700; cursor:pointer; white-space:nowrap; }
        .btn:disabled { opacity:.6; cursor:default; }
        .btn.ghost { background:#f0f0f2; color:#333; }
        .btn.amber { background:#b06f00; }
    </style>
</head>
<body>
    <div class="wrap">
        <header class="top">
            <h1>📊 #(halfLabel) 성과 취합</h1>
            <div class="meta">
                수정버전 <strong>배포일</strong> 기준 귀속 (GitHub Releases) · #if(platform):플랫폼 #(platform)#else:전체 플랫폼#endif
            </div>
            <div class="stats">
                <span class="chip">총 #(totalCount)건</span>
                <span class="chip">기획과제 #(planningCount)</span>
                <span class="chip">기술과제 #(technicalCount)</span>
                <span class="chip">KTLO #(ktloCount)</span>
                <span class="chip">크래시 #(crashCount)</span>
                <span class="chip gray">검토 #(unversionedCount)</span>
            </div>
        </header>

        <section class="bucket">
            <h2>🎯 기획과제 <span class="gcount" style="font-weight:400;">#(planningCount)건</span></h2>
            <p class="desc">🔒 = <code>기획과제</code>/<code>기술과제</code> 라벨이 이미 있어 자동 확정(수정 불가). 나머지는 프리필된 라디오로 확정 → "🏷 라벨 적용"으로 Jira에 write-back → 다음 반기 자동분류.</p>
            #if(count(planning) == 0):<p class="empty">해당 없음</p>#endif
            #for(g in planning):
            <div class="group #if(g.locked):locked#endif">
                <div class="ghead">
                    <div class="gtitle">📌 <a href="#(g.epicLink)" target="_blank">#(g.epicKey)</a> #(g.epicSummary)</div>
                    <div class="gcount">#if(g.ticketCount > 0):하위 #(g.ticketCount)#endif</div>
                </div>
                #if(g.locked):
                <span class="lockbadge">🔒 #(g.lockedLabel) · 라벨됨</span>
                #else:
                <div class="radios">
                    <label><input type="radio" name="d:#(g.epicKey)" value="planning" #if(g.category == "planning"):checked#endif><span>기획과제</span></label>
                    <label><input type="radio" name="d:#(g.epicKey)" value="technical" #if(g.category == "technical"):checked#endif><span>기술과제</span></label>
                    <label><input type="radio" name="d:#(g.epicKey)" value="excluded"><span>제외</span></label>
                </div>
                #endif
                #if(g.ticketCount > 0):
                <ul class="tks">
                    #for(t in g.tickets):
                    <li><a href="#(t.link)" target="_blank">#(t.key)</a> #(t.summary)<span class="v">#(t.versionLabel) · #(t.shipDateText)</span></li>
                    #endfor
                </ul>
                #endif
            </div>
            #endfor
        </section>

        <section class="bucket">
            <h2>🛠 기술과제 <span class="gcount" style="font-weight:400;">#(technicalCount)건</span></h2>
            #if(count(technical) == 0):<p class="empty">해당 없음</p>#endif
            #for(g in technical):
            <div class="group #if(g.locked):locked#endif">
                <div class="ghead">
                    <div class="gtitle">📌 <a href="#(g.epicLink)" target="_blank">#(g.epicKey)</a> #(g.epicSummary)</div>
                    <div class="gcount">#if(g.ticketCount > 0):하위 #(g.ticketCount)#endif</div>
                </div>
                #if(g.locked):
                <span class="lockbadge">🔒 #(g.lockedLabel) · 라벨됨</span>
                #else:
                <div class="radios">
                    <label><input type="radio" name="d:#(g.epicKey)" value="planning" #if(g.category == "planning"):checked#endif><span>기획과제</span></label>
                    <label><input type="radio" name="d:#(g.epicKey)" value="technical" #if(g.category == "technical"):checked#endif><span>기술과제</span></label>
                    <label><input type="radio" name="d:#(g.epicKey)" value="excluded"><span>제외</span></label>
                </div>
                #endif
                #if(g.ticketCount > 0):
                <ul class="tks">
                    #for(t in g.tickets):
                    <li><a href="#(t.link)" target="_blank">#(t.key)</a> #(t.summary)<span class="v">#(t.versionLabel) · #(t.shipDateText)</span></li>
                    #endfor
                </ul>
                #endif
            </div>
            #endfor
        </section>

        <section class="bucket">
            <h2>🔧 KTLO <span class="gcount" style="font-weight:400; color:#8a8a8e;">(자동)</span></h2>
            <p class="desc">KTLO 라벨 에픽(분기별)의 하위 운영 작업.</p>
            #if(count(ktlo) == 0):<p class="empty">해당 없음</p>#endif
            <ul class="tks">
                #for(t in ktlo):
                <li><a href="#(t.link)" target="_blank">#(t.key)</a> #(t.summary)<span class="v">#(t.versionLabel) · #(t.shipDateText)</span></li>
                #endfor
            </ul>
        </section>

        <section class="bucket">
            <h2>💥 크래시 대응 <span class="gcount" style="font-weight:400; color:#8a8a8e;">(자동)</span></h2>
            <p class="desc">크래시 연간 운영 에픽(KMA-8165)의 하위 대응 티켓.</p>
            #if(count(crash) == 0):<p class="empty">해당 없음</p>#endif
            <ul class="tks">
                #for(t in crash):
                <li><a href="#(t.link)" target="_blank">#(t.key)</a> #(t.summary)<span class="v">#(t.versionLabel) · #(t.shipDateText)</span></li>
                #endfor
            </ul>
        </section>

        #if(count(unversioned) > 0):
        <section class="bucket">
            <h2>❓ 검토 필요 (미배포/버전없음)</h2>
            <p class="desc">수정버전이 아직 배포 전이거나(버전 할당 대기) fixVersion이 없어 반기 귀속을 자동 판정하지 못한 항목. 수동 확인하세요.</p>
            <ul class="tks">
                #for(t in unversioned):
                <li><a href="#(t.link)" target="_blank">#(t.key)</a> #(t.summary)</li>
                #endfor
            </ul>
        </section>
        #endif
    </div>

    <div class="footer-bar">
        <div class="footer-inner">
            <input type="text" id="spaceKey" placeholder="Confluence Space Key (예: ~616f8e...)" value="#(spaceKey)">
            <button class="btn ghost" onclick="location.href='/moa/'">홈</button>
            <button class="btn amber" id="labelBtn" onclick="applyLabels()">🏷 라벨 적용</button>
            <button class="btn" id="wikiBtn" onclick="createWiki()">📝 위키 초안 생성</button>
        </div>
    </div>

    <script>
        const YEAR = #(year), HALF = #(half), PLATFORM = "#if(platform):#(platform)#endif";

        function collectDecisions() {
            const d = {};
            document.querySelectorAll('input[type=radio]:checked').forEach(r => {
                if (r.name.indexOf('d:') === 0) d[r.name.substring(2)] = r.value;
            });
            return d;
        }

        async function applyLabels() {
            if (!confirm('무라벨 과제에 기획과제/기술과제 라벨을 Jira에 실제로 부착합니다.\n(라벨 있는 건·제외는 건너뜀) 진행할까요?')) return;
            const btn = document.getElementById('labelBtn');
            btn.disabled = true; btn.innerText = '적용 중...';
            try {
                const res = await fetch('/moa/roundup/labels', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ year: YEAR, half: HALF, platform: PLATFORM, decisions: collectDecisions() })
                });
                if (!res.ok) { const t = await res.text(); let m=t; try{const j=JSON.parse(t); if(j.reason)m=j.reason;}catch(e){} throw new Error(m); }
                const j = await res.json();
                btn.innerText = '✅ ' + j.applied + '건 적용';
                alert('라벨 적용 ' + j.applied + '건 · 건너뜀 ' + j.skipped + '건\n\n' + (j.details || []).join('\n'));
            } catch (e) { alert('라벨 적용 실패: ' + e.message); btn.disabled = false; btn.innerText = '🏷 라벨 적용'; }
        }

        async function createWiki() {
            const spaceKey = document.getElementById('spaceKey').value.trim();
            if (!spaceKey) { alert('Confluence Space Key를 입력하세요.'); return; }
            const btn = document.getElementById('wikiBtn');
            btn.disabled = true; btn.innerText = '생성 중...';
            try {
                const res = await fetch('/moa/roundup/wiki', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ year: YEAR, half: HALF, platform: PLATFORM, spaceKey: spaceKey, decisions: collectDecisions() })
                });
                if (!res.ok) { const t = await res.text(); let m=t; try{const j=JSON.parse(t); if(j.reason)m=j.reason;}catch(e){} throw new Error(m); }
                const j = await res.json();
                btn.innerText = '✅ 생성됨 — 새 탭에서 열기';
                window.open(j.editUrl, '_blank');
            } catch (e) { alert('생성 실패: ' + e.message); btn.disabled = false; btn.innerText = '📝 위키 초안 생성'; }
        }
    </script>
</body>
</html>
